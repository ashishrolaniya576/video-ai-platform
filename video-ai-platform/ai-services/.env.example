# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info

# ── Compute device ────────────────────────────────────────────────────────────
# Options: auto | cuda | cpu
# "auto" detects CUDA availability at startup and falls back to CPU.
DEVICE=auto

# ── Directories ───────────────────────────────────────────────────────────────
OUTPUT_DIR=output
TEMP_DIR=temp
MODELS_DIR=models_weights

# ── Streaming ─────────────────────────────────────────────────────────────────
FRAME_BUFFER_SIZE=32

# ── RAFT Stabilizer ───────────────────────────────────────────────────────────
# Clone repo: git clone https://github.com/princeton-vl/RAFT.git
# Download weights: cd RAFT && bash download_models.sh
RAFT_REPO_PATH=RAFT
RAFT_MODEL_PATH=RAFT/models/raft-sintel.pth
RAFT_SMOOTHING_RADIUS=30
RAFT_CROP_RATIO=0.07
RAFT_FLOW_WIDTH=960
RAFT_FLOW_HEIGHT=540
RAFT_ITERS=20

# ── Heavy Rain Removal ────────────────────────────────────────────────────────
# Clone repo: git clone https://github.com/liruoteng/HeavyRainRemoval.git
# Download checkpoint from Dropbox (see README)
HEAVY_RAIN_REPO_PATH=HeavyRainRemoval
HEAVY_RAIN_CHECKPOINT=HeavyRainRemoval/.ckpt/HeavyRain-stage2-2019-05-11-76_ckpt.pth.tar

# ── Video Visibility (PromptIR) ───────────────────────────────────────────────
# Clone repo: git clone https://github.com/va1shn9v/PromptIR.git
# Download checkpoint: wget https://github.com/va1shn9v/PromptIR/releases/download/v1.0/model.ckpt
PROMPTIR_REPO_PATH=PromptIR
PROMPTIR_CHECKPOINT=models_weights/promptir_model.ckpt
PROMPTIR_TILE_SIZE=512
PROMPTIR_TILE_OVERLAP=32
PROMPTIR_CONTRAST_ALPHA=1.3
PROMPTIR_CONTRAST_BETA=10.0
PROMPTIR_CLAHE_CLIP=1.5

# ── Object Detection (YOLOv11n) ───────────────────────────────────────────────
# Weights auto-downloaded to models_weights/yolo11n.pt on first startup
YOLO_WEIGHTS_PATH=models_weights/yolo11n.pt
YOLO_CONFIDENCE_THRESHOLD=0.35
YOLO_IOU_THRESHOLD=0.45
